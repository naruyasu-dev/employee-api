<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "./mybatis-3-mapper.dtd">
<!--  "http://mybatis.org/dtd/mybatis-3-mapper.dtd" -->

<mapper namespace="com.example.employee_api.EmployeeMapper">

    <!-- 社員一覧取得 -->
    <select id="findAll" resultType="com.example.employee_api.Employee">
        SELECT
            id,
            name,
            department,
            department_id
        FROM
            employee
        ORDER BY
            id
    </select>

    <!-- 社員ID指定取得 -->
    <select id="findById" parameterType="long" resultType="com.example.employee_api.Employee">
        SELECT
            id,
            name,
            department,
            department_id
        FROM
            employee
        WHERE
            id = #{id}
    </select>

    <!-- 社員登録 -->
    <insert id="insert" parameterType="com.example.employee_api.Employee">
        INSERT INTO employee (
            name,
            department,
            department_id
        ) VALUES (
            #{name},
            #{department},
            #{departmentId}
        )
    </insert>

    <!-- 社員更新 -->
    <update id="update" parameterType="com.example.employee_api.Employee">
        UPDATE
            employee
        SET
            name = #{name},
            department = #{department},
            department_id = #{departmentId}
        WHERE
            id = #{id}
    </update>

    <!-- 社員削除 -->
    <delete id="delete" parameterType="long">
        DELETE FROM
            employee
        WHERE
            id = #{id}
    </delete>

    <!-- 社員検索 -->
    <select id="search" resultType="com.example.employee_api.Employee">
        SELECT
            id,
            name,
            department,
            department_id
        FROM
            employee
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%')
            </if>

            <if test="department != null and department != ''">
                AND department LIKE CONCAT('%', #{department}, '%')
            </if>
        </where>
        ORDER BY
            id
    </select>

</mapper>