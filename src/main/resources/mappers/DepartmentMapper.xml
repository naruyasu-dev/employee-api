<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.employee_api.DepartmentMapper">

    <!--
        部署マスタ一覧取得

        department_master テーブルから全件取得する。
    -->
    <select id="findAll" resultType="com.example.employee_api.Department">
        SELECT
            id,
            name,
            parent_id
        FROM
            department_master
        ORDER BY
            id
    </select>

    <!--
        部署マスタID指定取得

        指定された id の部署マスタ情報を1件取得する。
    -->
    <select id="findById" parameterType="long" resultType="com.example.employee_api.Department">
        SELECT
            id,
            name,
            parent_id
        FROM
            department_master
        WHERE
            id = #{id}
    </select>

    <!--
        部署マスタ登録
    -->
    <insert id="insert" parameterType="com.example.employee_api.Department">
        INSERT INTO department_master (
            name,
            parent_id
        ) VALUES (
            #{name},
            #{parentId}
        )
    </insert>

    <!--
        部署マスタ更新
    -->
    <update id="update" parameterType="com.example.employee_api.Department">
        UPDATE
            department_master
        SET
            name = #{name},
            parent_id = #{parentId}
        WHERE
            id = #{id}
    </update>

    <!--
        部署マスタ削除
    -->
    <delete id="delete" parameterType="long">
        DELETE FROM
            department_master
        WHERE
            id = #{id}
    </delete>

    <!--
        部署マスタ検索

        keyword が指定された場合、部署名で部分一致検索する。
        keyword が未指定の場合は全件取得する。
    -->
    <select id="search" resultType="com.example.employee_api.Department">
        SELECT
            id,
            name,
            parent_id
        FROM
            department_master
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY
            id
    </select>

</mapper>